@page "/leavetypes/"

<h3>Leave Types</h3>

<div class="m-2 d-flex justify-content-end">
	<button @onclick="CreateLeaveType" class="btn btn-success">Add Leave Typs</button>
</div>

@if (string.IsNullOrEmpty(Message) == false)
{
	<div class="alert alert-danger">
		@Message
	</div>
}

@if(LeaveTypes == null)
{
	<p>Loading Data...</p>
}
else
{
	<table class="table">
		<thead>
			<tr>
				<th>
					Id
				</th>
				<th>
					Name
				</th>
				<th>
					Default Days
				</th>
				<th>Actions</th>
			</tr>
		</thead>
		<tbody>
			@foreach(var item in LeaveTypes)
			{
				<tr>
					<td>
						@item.Id
					</td>
					<td>
						@item.Name
					</td>
					<td>
						@item.DefaultDays
					</td>
					<td>
						<button @onclick=@(() => AllocateLeaveType(item.Id))
							class="btn btn-dark">Allocate Leave
							</button>
						<button @onclick=@(() => EditLeaveType(item.Id)) class="btn btn-warning">Edit</button>
						<button @onclick=@(() => DetailsLeaveType(item.Id)) class="btn btn-info">Details</button>
						<button @onclick=@(() => DeleteLeaveType(item.Id)) class="btn btn-danger">Delete</button>
					</td>
				</tr>
			}
		</tbody>
	</table>
}
